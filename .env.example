# Local SoftwareX reproduction profile.
# Copy to .env and replace placeholders if needed.

POSTGRES_PASSWORD=CHANGE_ME_LOCAL_POSTGRES
EDC_API_AUTH_KEY=CHANGE_ME_LOCAL_EDC_API_KEY
LOCAL_ASSETS_AUTH_TOKEN=CHANGE_ME_LOCAL_ASSET_TOKEN

# ArcGIS login is disabled for the local reproducibility path.
ARCGIS_AUTH_ENABLED=false
ARCGIS_PORTAL_URL=
ARCGIS_CLIENT_ID=
ARCGIS_REDIRECT_URI=http://localhost:12000/
ARCGIS_REQUIRED_ORG_ID=
ARCGIS_REQUIRED_GROUP_ID=
ARCGIS_UC3M_GROUP_ID=
ARCGIS_FUENLA_GROUP_ID=

# Email notifications are disabled by default.
CAAS_SMTP_HOST=
CAAS_SMTP_PORT=587
CAAS_SMTP_USER=
CAAS_SMTP_PASSWORD=
CAAS_SMTP_FROM=TOPIC Connector <no-reply@example.org>
CAAS_SMTP_USE_TLS=true
